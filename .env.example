# Recipe Vault — environment. Copy to .env.local and fill. NEVER commit .env.local.

# Airtable (server-side only — never exposed to the browser)
AIRTABLE_PAT=pat_xxx_scoped_to_recipe_vault_base
AIRTABLE_BASE_ID=app6mZdKQY54dybGR

# Auth — a single passcode for Reba + a random secret to sign the session cookie
APP_PASSCODE=choose-a-passcode
AUTH_SECRET=generate-a-long-random-string
